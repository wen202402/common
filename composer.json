{
  "name": "fater/common",
  "type": "library",
  "description": "A small PHP library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "yiisoft/yii2": "~2.0.45"
  },
  "require-dev": {
    "swoole/ide-helper": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "fater\\common\\": "src/"
    }
  },
  "provide": {
    "bower-asset/jquery": "*",
    "bower-asset/bootstrap": "*",
    "bower-asset/inputmask": "*",
    "bower-asset/punycode": "*",
    "bower-asset/yii2-pjax": "*",
    "bower-asset/bootstrap-switch": "3.3.*",
    "npm-asset/bootstrap": "^4.3"
  },
  "config": {
    "process-timeout": 1800,
    "fxp-asset": {
      "enabled": false
    },
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true

    }
  }
}
